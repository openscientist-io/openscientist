[run]
source = src/open_scientist
omit =
    */tests/*
    */__pycache__/*
    */.venv/*
relative_files = True
disable_warnings = no-data-collected
cover_pylib = False

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

[paths]
source = src/open_scientist
