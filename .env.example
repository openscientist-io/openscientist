# OpenScientist Environment Configuration
# Copy this file to .env and fill in your values.
#
# Loading priority: env vars > .env > defaults


#############################################
# SERVER
#############################################
# PORT=8080                                       # Web server port
# OPENSCIENTIST_BASE_URL=http://localhost:8080           # Base URL for notifications and share links
# APP_URL=http://localhost:8080                   # Base URL for OAuth callback URLs
# OPENSCIENTIST_MAX_CONCURRENT_JOBS=1                    # Max jobs running at the same time


#############################################
# PROVIDER SELECTION & MODEL OVERRIDES
#############################################
# Which LLM backend to use.
CLAUDE_PROVIDER=anthropic  # anthropic | cborg | vertex | bedrock | codex | foundry

# Model overrides (optional — each provider has sensible defaults)
# ANTHROPIC_MODEL=claude-sonnet-4-6               # Main model
# ANTHROPIC_SMALL_FAST_MODEL=claude-haiku-4-5-20251001  # Small/fast model for lightweight tasks


#############################################
# PROVIDER CREDENTIALS (set the section for your chosen provider)
#############################################

# --- Option 1a: Direct Anthropic API ---
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# --- Option 1b: Anthropic OAuth (from `claude login`) ---
# CLAUDE_CODE_OAUTH_TOKEN=  # run: claude setup-token

# --- Option 2: CBORG (Lawrence Berkeley National Lab) ---
# ANTHROPIC_AUTH_TOKEN=sk-ant-your-token-here
# ANTHROPIC_BASE_URL=https://api.cborg.lbl.gov

# --- Option 3: Google Vertex AI ---
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# GCP_CREDENTIALS_FILE=/path/to/service-account.json             # host path; mounted into container by docker-compose
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json   # app-level path (set automatically in Docker)
# GCP_CREDENTIALS_HOST_PATH=/host/path/to/service-account.json   # explicit host path for agent container mounts
# GCP_BILLING_ACCOUNT_ID=XXXXXX-YYYYYY-ZZZZZZ
# CLOUD_ML_REGION=us-east5
# VERTEX_REGION_CLAUDE_4_5_SONNET=us-east5
# VERTEX_REGION_CLAUDE_4_5_HAIKU=us-east5

# --- Option 4: AWS Bedrock ---
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_PROFILE=your-profile-name                   # alternative to access keys
# AWS_BEARER_TOKEN_BEDROCK=your-token             # alternative auth method
# Note: Bedrock model IDs need the "us." prefix — set ANTHROPIC_MODEL accordingly

# --- Option 5: Azure AI Foundry ---
# ANTHROPIC_FOUNDRY_RESOURCE=your-resource-name
# ANTHROPIC_FOUNDRY_API_KEY=your-azure-api-key
# ANTHROPIC_FOUNDRY_BASE_URL=https://your-resource.services.ai.azure.com/anthropic
#
# Azure Cost Management (optional — enables billing data in admin panel)
# Requires a service principal with "Cost Management Reader" role on the subscription/resource group.
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_RESOURCE_GROUP=your-resource-group      # optional; scopes query to one RG
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret


#############################################
# DATABASE
#############################################
# Docker: docker-compose.yml constructs DATABASE_URL from these + service hostname.
POSTGRES_USER=openscientist
POSTGRES_PASSWORD=openscientist_dev_password
POSTGRES_DB=openscientist
POSTGRES_PORT=5434                                # host port; avoids conflicts with other PostgreSQL instances

# App: only DATABASE_URL matters (required).
# For local dev (no Docker), set these directly:
DATABASE_URL=postgresql+asyncpg://openscientist:openscientist_dev_password@localhost:5434/openscientist
ADMIN_DATABASE_URL=postgresql+asyncpg://openscientist_admin:openscientist_dev_password@localhost:5434/openscientist
# SQL_ECHO=false                                  # Set true to log all SQL queries


#############################################
# SECRETS
#############################################
# Master secret — derives storage_secret and token_encryption_key via HMAC-SHA256.
# Generate with: openssl rand -hex 32
OPENSCIENTIST_SECRET_KEY=your-64-char-hex-master-secret-here


#############################################
# OAUTH (optional — enables real user login)
#############################################
# Google OAuth (https://console.cloud.google.com/apis/credentials)
# GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# GitHub OAuth
# GITHUB_CLIENT_ID=your-github-oauth-client-id
# GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ORCID OAuth (https://orcid.org/developer-tools)
# ORCID_CLIENT_ID=APP-XXXXXXXXXXXX
# ORCID_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional bootstrap admins (comma-separated exact emails).
# Matching verified OAuth logins are auto-granted admin and approved status.
# BOOTSTRAP_ADMIN_EMAILS=admin1@example.org,admin2@example.org

# SESSION_DURATION_DAYS=30                        # Session cookie lifetime in days

# GitHub token for skill syncing from private repos (optional)
# GITHUB_TOKEN=ghp_your-token-here


#############################################
# BUDGET LIMITS (optional — all have safe defaults)
#############################################
# MAX_JOB_COST_USD=10.0                           # Per-job cost cap
# MAX_PROJECT_SPEND_WARN=100.0                    # Warning threshold for project spend
# MAX_PROJECT_SPEND_HARD=500.0                    # Hard limit for project spend
# APP_MAX_BUDGET_USD=1000.0                       # Global app budget
# MAX_PROJECT_SPEND_TOTAL_USD=inf                 # Total project spend limit
# MAX_PROJECT_SPEND_24H_USD=inf                   # 24-hour spend limit
# WARN_PROJECT_SPEND_24H_USD=inf                  # 24-hour warning threshold


#############################################
# CONTAINER ISOLATION (optional)
#############################################
# OPENSCIENTIST_USE_CONTAINER_ISOLATION=false            # Enable container-per-job isolation
# OPENSCIENTIST_EXECUTOR_IMAGE=openscientist-executor:latest    # Docker image for code execution
# OPENSCIENTIST_EXECUTOR_MEMORY=2g                       # Executor memory limit
# OPENSCIENTIST_EXECUTOR_CPU=0.5                         # Executor CPU limit
# OPENSCIENTIST_EXECUTOR_TIMEOUT=120                     # Executor timeout in seconds
# OPENSCIENTIST_AGENT_MEMORY=8g                          # Agent container memory limit
# OPENSCIENTIST_AGENT_CPU=2.0                            # Agent container CPU limit
# OPENSCIENTIST_CONTAINER_APP_DIR=/app                   # App path inside container
# OPENSCIENTIST_HOST_PROJECT_DIR=                        # Host path for project dir (required for agent containers)
# OPENSCIENTIST_PLATFORM=linux/amd64                     # Docker platform for web container (unset = native)
# OPENSCIENTIST_AGENT_PLATFORM=linux/amd64               # Docker platform for agent containers (set to linux/amd64 on Apple Silicon for Phenix)

# MAX_FILE_SIZE_MB=1000                           # Max upload file size in MB
# MAX_AGENT_SKILLS=10                             # Max skills per agent job


#############################################
# PHENIX (optional — structural biology tools)
#############################################
# Phenix 2.x is mounted read-only at /opt/phenix inside all containers.
# You MUST use a Linux x86_64 Phenix build (even when developing on macOS),
# because all containers run Linux.
#
# Setup:
#   1. Download the Linux x86_64 installer from https://phenix-online.org
#      (free for academics; choose "Phenix installer for Linux x86_64").
#   2. Run the installer on a Linux host (or via a Linux container on macOS):
#        bash Phenix-2.0-*-Linux-x86_64.sh -b -p /path/to/phenix-2.0-XXXX
#      Note: on macOS, install into a case-sensitive APFS volume
#      (the default case-insensitive one collides on some bundled files).
#   3. Set PHENIX_HOST_PATH to the install directory below.
#
# PHENIX_HOST_PATH=/path/to/phenix-2.0-5936


#############################################
# BERKELEY LAB DATA LAKEHOUSE (optional)
#############################################
# DREMIO_USER=your-dremio-username
# DREMIO_PASSWORD=your-dremio-password


#############################################
# DEVELOPMENT
#############################################
# Dev mode enables mock OAuth login and other development features.
OPENSCIENTIST_DEV_MODE=false
