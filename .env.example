# SHANDY Environment Configuration Example
# Copy this file to .env and fill in your values

# CBORG API Configuration
ANTHROPIC_AUTH_TOKEN=sk-ant-your-token-here
ANTHROPIC_BASE_URL=https://api.cborg.lbl.gov
ANTHROPIC_MODEL=anthropic/claude-sonnet

# Application Configuration
PORT=8602
STORAGE_SECRET=change-this-to-a-random-secret-string-in-production

# Cost Limits
MAX_JOB_COST_USD=10.00           # Stop if single job exceeds this
APP_MAX_BUDGET_USD=1000.00       # Total application spending limit
WARN_COST_THRESHOLD_USD=5.00     # Warn user when job reaches this threshold

# Skills Configuration
SKILLS_ENABLED=true              # Global default for using skills
ALLOW_SKILLS_TOGGLE=true         # Let users override per-job

# Optional: Authentication
DISABLE_AUTH=false
# To generate password hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
APP_PASSWORD_HASH=

# Data paths (if not using Docker volumes)
DATA_DIR=/data
JOBS_DIR=/jobs

# Optional: Clean storage on startup
CLEAN_STORAGE=false
CLEAN_PLOTS=true
