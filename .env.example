# SHANDY Environment Configuration Example
# Copy this file to .env and fill in your values

#############################################
# PROVIDER CONFIGURATION
#############################################
# Choose one provider: cborg, vertex, bedrock, or foundry
# See README.md for detailed setup instructions

# Option 1: CBORG (Lawrence Berkeley National Lab)
# CLAUDE_PROVIDER=cborg
# ANTHROPIC_AUTH_TOKEN=sk-ant-your-token-here
# ANTHROPIC_BASE_URL=https://api.cborg.lbl.gov

# Option 2: Google Vertex AI
# See: https://docs.anthropic.com/en/docs/claude-code/vertex
# CLAUDE_PROVIDER=vertex
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# GCP_CREDENTIALS_FILE=/path/to/your/service-account.json
# Just to satisfy Vertex, in the docker it is hardcoded to an internal path.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
# CLOUD_ML_REGION=us-east5
# VERTEX_REGION_CLAUDE_4_5_SONNET=us-east5
# VERTEX_REGION_CLAUDE_4_5_HAIKU=us-east5
# GCP_BILLING_ACCOUNT_ID=XXXXXX-YYYYYY-ZZZZZZ

# Option 3: AWS Bedrock
# See: https://docs.anthropic.com/en/docs/claude-code/bedrock
# CLAUDE_PROVIDER=bedrock
# AWS_REGION=us-east-1
# Authentication (choose one method):
#   Method A: Access keys (recommended)
#   AWS_ACCESS_KEY_ID=your-access-key-id
#   AWS_SECRET_ACCESS_KEY=your-secret-access-key
#   Method B: AWS profile
#   AWS_PROFILE=your-profile-name
# Models - REQUIRED for Bedrock:
#   Must use "us." prefix for cross-region inference profiles.
#   Without the prefix you'll get "on-demand throughput isn't supported" errors.
# ANTHROPIC_MODEL=us.anthropic.claude-opus-4-6-v1
# ANTHROPIC_SMALL_FAST_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Option 4: Azure AI Foundry (Microsoft Foundry)
# See: https://code.claude.com/docs/en/microsoft-foundry
# CLAUDE_PROVIDER=foundry
# REQUIRED: Enable Claude Code Foundry mode
# CLAUDE_CODE_USE_FOUNDRY=1
# Azure resource configuration (choose ONE - they are mutually exclusive!):
#   Method A: Resource name (recommended)
#   ANTHROPIC_FOUNDRY_RESOURCE=your-resource-name
#   Method B: Full base URL (don't set if using RESOURCE)
#   ANTHROPIC_FOUNDRY_BASE_URL=https://your-resource.services.ai.azure.com/anthropic
# IMPORTANT: Do NOT set both RESOURCE and BASE_URL - Claude Code will error!
# Authentication (choose one method):
#   Method A: API key (recommended for testing)
#   ANTHROPIC_FOUNDRY_API_KEY=your-azure-api-key
#   Method B: Azure Entra ID (automatic - uses Azure default credential chain)
#   (No API key needed - run "az login" or configure managed identity)
# Model deployment names (optional - defaults shown):
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
# Cost tracking via Azure Cost Management API (optional but recommended):
#   Find your subscription ID in Azure Portal > Subscriptions
#   Enables real-time cost monitoring in SHANDY web interface
# AZURE_SUBSCRIPTION_ID=your-subscription-id

# Option 5: Direct Anthropic API (bring your own key)
# Get your API key from https://console.anthropic.com
# CLAUDE_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

#############################################
# IMPORTANT: Provider Conflicts
#############################################
# Only configure ONE provider above. Mixing variables causes auth errors.
#
# If switching from Vertex to Bedrock, ensure these are NOT set:
#   CLAUDE_CODE_USE_VERTEX, ANTHROPIC_VERTEX_PROJECT_ID, VERTEX_REGION_*
#
# If switching from Bedrock to Vertex, ensure these are NOT set:
#   CLAUDE_CODE_USE_BEDROCK, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
#
# If switching to Foundry, ensure other provider variables are NOT set:
#   CLAUDE_CODE_USE_VERTEX, CLAUDE_CODE_USE_BEDROCK, ANTHROPIC_API_KEY
#
# Empty strings also cause issues (e.g., AWS_PROFILE= with no value).
# Either set a real value or don't include the variable at all.
#
# SHANDY's provider code handles these conflicts automatically in Docker,
# but local development may need manual cleanup of your .env file.

#############################################
# MODEL SELECTION
#############################################
# Model IDs vary by provider:
#   - Anthropic API: claude-opus-4-5@20251101
#   - Vertex AI: claude-opus-4-5@20251101 (same format)
#   - Bedrock: us.anthropic.claude-opus-4-6-v1 (must use us. prefix!)
#   - Foundry: claude-opus-4-6 (deployment names you created in Azure)
#   - CBORG: anthropic/claude-sonnet (org/model format)
# Set these in the provider section above, not here.

#############################################
# BUDGET CONTROLS (Optional)
#############################################
# Application-level budget limits
# Checks are performed before job creation

# Maximum total spend across all jobs (USD)
# MAX_PROJECT_SPEND_TOTAL_USD=1000

# Maximum spend in last 24 hours (USD)
# MAX_PROJECT_SPEND_24H_USD=50

#############################################
# DATABASE
#############################################
# PostgreSQL database configuration
# These are automatically used by docker-compose.yml

# Database connection details
POSTGRES_USER=shandy
POSTGRES_PASSWORD=shandy_dev_password
POSTGRES_DB=shandy
# Using port 5434 to avoid conflicts with other PostgreSQL instances
POSTGRES_PORT=5434

# Connection URL (constructed automatically in docker-compose.yml)
# If connecting from host, use: postgresql+asyncpg://shandy:shandy_dev_password@localhost:5434/shandy
DATABASE_URL=postgresql+asyncpg://shandy:shandy_dev_password@postgres:5432/shandy
ADMIN_DATABASE_URL=postgresql+asyncpg://shandy_admin:shandy_dev_password@postgres:5432/shandy

#############################################
# WEB APPLICATION
#############################################
# Port for web interface
PORT=8080

# Storage secret for session management (change in production!)
STORAGE_SECRET=change-this-to-a-random-secret-string-in-production

# Application URL (used for OAuth callbacks)
APP_URL=http://localhost:8080

# Session configuration
SESSION_SECRET=change-this-to-a-random-secret-string-in-production
SESSION_DURATION_DAYS=30

# OAuth Configuration (recommended for multi-user authentication)
# GitHub OAuth (create app at https://github.com/settings/developers)
# Set callback URL to: http://your-domain:8080/auth/github/callback
# GITHUB_CLIENT_ID=your-github-oauth-client-id
# GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ORCID OAuth (create app at https://orcid.org/developer-tools)
# Set redirect URI to: http://your-domain:8080/auth/orcid/callback
# ORCID_CLIENT_ID=your-orcid-client-id
# ORCID_CLIENT_SECRET=your-orcid-client-secret
# ORCID_API_BASE=https://orcid.org  # Use https://sandbox.orcid.org for testing

# Mock OAuth (DEVELOPMENT ONLY - never enable in production!)
# Provides a simple login form for testing without real OAuth providers
# Automatically enabled in docker-compose.dev.yml
# See docs/MOCK_OAUTH.md for details
# ENABLE_MOCK_AUTH=true
# Security: encryption key for OAuth tokens (required)
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=your-randomly-generated-token-encryption-key-here

#############################################
# SKILLS CONFIGURATION
#############################################
# Global default for using skills
SKILLS_ENABLED=true

# Allow users to toggle skills per job
ALLOW_SKILLS_TOGGLE=true

#############################################
# PHENIX (Optional - for structural biology)
#############################################
# Path to Phenix installation
# Enables tools: run_phenix_tool, compare_structures, parse_alphafold_confidence
# If not set, Phenix tools are unavailable but other features work normally

# Docker default (if Phenix is installed):
PHENIX_PATH=/opt/phenix-1.21.2-5419

# See docs/PHENIX_SETUP.md for installation instructions

#############################################
# BERKELEY LAB DATA LAKEHOUSE (Optional)
#############################################
# Credentials for querying genomics data lakehouses
# See .claude/skills/domain/kbase-query/ and jgi-lakehouse/

# KBase/BERDL REST API
# Get token from KBase JupyterHub: BERDLSettings().KBASE_AUTH_TOKEN
# Note: Tokens expire after ~1 week
# KBASE_TOKEN=your-kbase-token-here

# JGI Dremio Lakehouse (GOLD, IMG databases)
# Requires authorized access to JGI lakehouse
# DREMIO_USER=your-dremio-username
# DREMIO_PASSWORD=your-dremio-password

#############################################
# ADVANCED CONFIGURATION
#############################################
# Claude Code CLI path (default: claude)
# CLAUDE_CLI_PATH=claude

# Data paths (Docker volumes handle these automatically)
# DATA_DIR=/data
# JOBS_DIR=/jobs

# Maximum file size for uploads (in MB)
# Default: 500MB if not set
# MAX_FILE_SIZE_MB=500

# Clean storage on startup
# CLEAN_STORAGE=false
# CLEAN_PLOTS=true
