#############################################
# PROVIDER CONFIGURATION
#############################################

# Provider selection: cborg, vertex, or bedrock
CLAUDE_PROVIDER=bedrock

# Option 1: CBORG (commented out)
# ANTHROPIC_AUTH_TOKEN=your-cborg-token
# ANTHROPIC_BASE_URL=https://api.cborg.lbl.gov
# ANTHROPIC_MODEL=anthropic/claude-sonnet
# ANTHROPIC_SMALL_FAST_MODEL=anthropic/claude-haiku

# Option 2: Google Vertex AI (commented out)
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-credentials.json
# CLOUD_ML_REGION=us-east5
# VERTEX_REGION_CLAUDE_4_5_SONNET=us-east5
# VERTEX_REGION_CLAUDE_4_5_HAIKU=us-east5
# GCP_BILLING_ACCOUNT_ID=XXXXXX-YYYYYY-ZZZZZZ

# Option 3: AWS Bedrock (ACTIVE)
CLAUDE_CODE_USE_BEDROCK=1
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Models - REQUIRED for Bedrock. Must use "us." prefix for cross-region inference profiles.
# Without the us. prefix you'll get: "Invocation with on-demand throughput isn't supported"
ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
ANTHROPIC_SMALL_FAST_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Application Configuration
PORT=8080
STORAGE_SECRET=change-this-to-a-random-secret-string-in-production

#############################################
# BUDGET CONTROLS (Optional)
#############################################
# Application-level budget limits
MAX_PROJECT_SPEND_TOTAL_USD=1000
MAX_PROJECT_SPEND_24H_USD=50

# Skills Configuration
SKILLS_ENABLED=true              # Global default for using skills
ALLOW_SKILLS_TOGGLE=true         # Let users override per-job

#############################################
# BERKELEY LAB DATA LAKEHOUSE
#############################################
# KBase/BERDL REST API (tokens expire after ~1 week)
# KBASE_TOKEN=your-kbase-token

# JGI Dremio Lakehouse (GOLD, IMG databases)
# DREMIO_USER=your-dremio-username
# DREMIO_PASSWORD=your-dremio-password

# Optional: Authentication
DISABLE_AUTH=false
# To generate password hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
# Default password: shandy123
# NOTE: APP_PASSWORD_HASH is set in docker-compose.yml to avoid variable substitution issues
#APP_PASSWORD_HASH='$2b$12$H77l168RKZRcRlElvBqr.O7UZxarzIZU9LUfPDsHvb/DmeekUUKZa'

# Data paths (if not using Docker volumes)
DATA_DIR=/data
JOBS_DIR=/jobs

# Maximum file size for uploads (in MB)
# Default: 500MB if not set
#MAX_FILE_SIZE_MB=500

# Optional: Clean storage on startup
CLEAN_STORAGE=false
CLEAN_PLOTS=true

# Phenix Configuration (for structural biology features)
# For local Mac development: Use macOS installation path
# For Docker (x86_64 servers): Use /opt/phenix-1.21.2-5419
# PHENIX_PATH=/opt/phenix-1.21.2-5419
