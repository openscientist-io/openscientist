*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv

# Jobs and data (mounted as volumes)
jobs/
data/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Documentation
notes/
*.md
!CLAUDE.md

# Environment
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
dist/
build/
*.egg-info/
