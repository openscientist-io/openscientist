# Dockerfile.agent — shandy-agent image
#
# Runs a single SHANDY job in an isolated container.
# Builds on shandy-base (Python 3.12, uv, git) and installs the full
# shandy package so the agent can import orchestrator/discovery code.
#
# Build:
#   docker build -f Dockerfile.agent -t shandy-agent:latest .
#
# Labels:
#   shandy.job_id=<uuid>   set by JobContainerRunner at runtime
#   shandy.type=agent

FROM shandy-base:latest

# Install system dependencies for native extensions (scipy, h5py, scanpy, etc.) and Rust
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libhdf5-dev \
    pkg-config \
    rustc \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd --uid 1001 --create-home --shell /bin/bash agent

WORKDIR /app

# Copy project files (README.md required by pyproject.toml readme field)
COPY pyproject.toml README.md uv.lock* ./
COPY src/ ./src/

# Install dependencies including claude-agent-sdk
# (claude-agent-sdk is listed in pyproject.toml dependencies)
RUN uv pip install --system -e .

# Copy agent entrypoint
COPY docker/agent-entrypoint.py /agent-entrypoint.py

# Install CLAUDE.md for the agent user (picked up by Claude Code as the user-level CLAUDE.md)
RUN mkdir -p /home/agent/.claude
COPY JOB_CLAUDE.md /home/agent/.claude/CLAUDE.md
RUN chown -R agent:agent /home/agent/.claude

# Switch to non-root user
USER agent

# Job directory will be mounted at /agent/job
WORKDIR /agent/job

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

ENTRYPOINT ["python", "/agent-entrypoint.py"]
