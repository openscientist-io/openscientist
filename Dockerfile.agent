# Dockerfile.agent — open-scientist-agent image
#
# Runs a single Open Scientist job in an isolated container.
# Builds on open_scientist-base (Python 3.12, uv, git) and installs the full
# open_scientist package so the agent can import orchestrator/discovery code.
#
# Build:
#   docker build -f Dockerfile.agent -t open-scientist-agent:latest .
#
# Labels:
#   open_scientist.job_id=<uuid>   set by JobContainerRunner at runtime
#   open_scientist.type=agent

FROM open_scientist-base:latest

# Install system dependencies for native extensions (scipy, h5py, scanpy, etc.) and Rust
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libhdf5-dev \
    pkg-config \
    rustc \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd --uid 1001 --create-home --shell /bin/bash agent

WORKDIR /app

# Copy project files (README.md required by pyproject.toml readme field)
COPY pyproject.toml README.md uv.lock* ./
COPY src/ ./src/

# Install dependencies including claude-agent-sdk
# (claude-agent-sdk is listed in pyproject.toml dependencies)
RUN uv pip install --system -e .

# Copy agent entrypoint
COPY docker/agent-entrypoint.py /agent-entrypoint.py

# Switch to non-root user
USER agent

# Job directory will be mounted at /agent/job
WORKDIR /agent/job

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

ENTRYPOINT ["python", "/agent-entrypoint.py"]
